# ====================================
# Mr.Holmes CRM - Environment Configuration
# ====================================

# ---- DATABASE ----
DATABASE_URL=postgresql://crm_admin:changeme123@localhost:5432/crm_db
DB_NAME=crm_db
DB_USER=crm_admin
DB_PASSWORD=changeme123
DB_HOST=localhost
DB_PORT=5432

# ---- REDIS ----
REDIS_URL=redis://:changeme123@localhost:6379/0
REDIS_PASSWORD=changeme123

# ---- SECURITY ----
JWT_SECRET_KEY=your-secret-key-change-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ---- API ----
API_PORT=8000
API_HOST=0.0.0.0
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8512"]
API_TITLE=Mr.Holmes CRM API
API_VERSION=1.0.0

# ---- STREAMLIT ----
STREAMLIT_SERVER_PORT=8512
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_CLIENT_TOOLBARPOSITION=top

# ---- INTEGRATIONS ----
# Assistente IA (DeepSeek) — chat de dúvidas nos guias de serviço
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=+55 (your whatsapp number)

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Slack (for notifications)
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_WEBHOOK_URL=your_slack_webhook_url

# ---- COMPLIANCE ----
# LGPD
GDPR_ENABLED=true
DATA_RETENTION_DAYS=2555
ENCRYPTION_KEY=your-32-char-encryption-key-1234567890abcdefghijklmnop

# ---- MONITORING ----
LOG_LEVEL=INFO
SENTRY_DSN=
DATADOG_API_KEY=
DATADOG_APP_KEY=

# ---- DEPLOYMENT ----
ENVIRONMENT=production
DEBUG=false
ALLOWED_HOSTS=["localhost", "yourdomain.com"]

# ---- AWS (Optional) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=crm-backups

# ---- BACKUP ----
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
